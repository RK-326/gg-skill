# Скопируй этот файл в ".env" и впиши настоящие ключи.
# .env в git НЕ попадает (см. .gitignore) и никуда не пушится.
# Перед запуском скриптов: source .env

# Perplexity (фактчек). Ключ начинается на pplx-
export PPLX_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxx

# OpenRouter (ключ от Льва, кап $10). Ключ начинается на sk-or-
export OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx

# Модели OpenRouter: текст — Gemini 3 Pro; картинки — image-модель
# (Gemini Pro картинки НЕ рисует, нужна именно image-модель).
export OPENROUTER_TEXT_MODEL=google/gemini-3.1-pro-preview
export OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
