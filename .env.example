# Скопируй этот файл в ".env" и впиши настоящие ключи.
# .env в git НЕ попадает (см. .gitignore) и никуда не пушится.
# Перед запуском скриптов: source .env

# Perplexity (фактчек). Ключ начинается на pplx-
export PPLX_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxx

# OpenRouter (картинки, модель google/gemini-2.5-flash-image). Ключ от Льва.
# Ключ начинается на sk-or-
export OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
